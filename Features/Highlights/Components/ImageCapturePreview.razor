@implements IAsyncDisposable

<div class="camera-capture-shell">
    <div class="camera-stage">
        @if (_shouldRenderCameraPreview)
        {
            <video id="@_videoElementId"
                   class="camera-preview-video"
                   autoplay
                   playsinline
                   muted></video>
        }
        else if (!string.IsNullOrWhiteSpace(ImageBase64))
        {
            <MudImage Src="@ImageBase64"
                      Alt="Preview da imagem capturada"
                      Fluid="true"
                      Class="preview-image" />
        }
        else
        {
            <MudStack Class="camera-placeholder"
                      Spacing="2"
                      AlignItems="AlignItems.Center"
                      Justify="Justify.Center">
                <MudIcon Icon="@Icons.Material.Filled.PhotoCamera" Size="Size.Large" />
                <MudText Typo="Typo.body1" Align="Align.Center">
                    Preparando a experiencia de captura...
                </MudText>
            </MudStack>
        }

        <div class="camera-overlay-gradient"></div>

        <MudStack Class="camera-top-hint" Spacing="1">
            @if (IsMobile)
            {
                <MudStack Row="true" Justify="Justify.FlexEnd" AlignItems="AlignItems.Center">
                    <MudButton Variant="Variant.Text"
                               Color="Color.Default"
                               Class="camera-cancel-button"
                               OnClick="CloseAsync">
                        Cancelar
                    </MudButton>
                </MudStack>
            }

            <MudText Typo="Typo.subtitle1" Class="camera-overlay-text">
                Posicione o texto dentro da moldura
            </MudText>
            @if (!string.IsNullOrWhiteSpace(_cameraErrorMessage))
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Dense="true">
                    @_cameraErrorMessage
                </MudAlert>
            }
        </MudStack>

        <div class="camera-focus-frame"></div>

        <MudStack Class="camera-controls" Spacing="2" AlignItems="AlignItems.Center">
            @if (IsProcessing || _isStartingCamera || _isCapturingPhoto)
            {
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                    <MudProgressCircular Indeterminate="true" Size="Size.Medium" Color="Color.Default" />
                    <MudText Typo="Typo.body2" Class="camera-overlay-text">@StatusMessage</MudText>
                </MudStack>
            }

            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Justify="Justify.Center">
                <MudButton Variant="Variant.Text"
                           Color="Color.Default"
                           Class="camera-secondary-action"
                           Disabled="@(_isStartingCamera || IsProcessing)"
                           OnClick="ToggleCameraAsync">
                    Trocar
                </MudButton>

                <MudIconButton Icon="@Icons.Material.Filled.Camera"
                               Color="Color.Primary"
                               Size="Size.Large"
                               Class="camera-shutter-button"
                               Disabled="@(!_isCameraActive || _isCapturingPhoto || IsProcessing)"
                               OnClick="CapturePhotoAsync" />

                <label class="camera-secondary-action upload-trigger">
                    <InputFile OnChange="OnFileSelected"
                               accept="image/*"
                               class="camera-upload-input" />
                    Galeria
                </label>
            </MudStack>

            @if (!string.IsNullOrWhiteSpace(FileName) && !string.IsNullOrWhiteSpace(ImageBase64))
            {
                <MudText Typo="Typo.caption" Class="camera-overlay-text">
                    @FileName
                </MudText>
            }
        </MudStack>
    </div>
</div>

@code {
    private const long MaxFileSize = 10 * 1024 * 1024;
    private readonly string _videoElementId = $"camera-preview-{Guid.NewGuid():N}";
    private bool _isCameraActive;
    private bool _isStartingCamera;
    private bool _isCapturingPhoto;
    private bool _shouldRenderCameraPreview;
    private bool _pendingCameraStart;
    private string _preferredFacingMode = "environment";
    private string? _cameraErrorMessage;

    [Inject]
    private IJSRuntime JsRuntime { get; set; } = default!;

    [Parameter]
    public string? ImageBase64 { get; set; }

    [Parameter]
    public string? FileName { get; set; }

    [Parameter]
    public bool IsProcessing { get; set; }

    [Parameter]
    public bool AutoStartCamera { get; set; }

    [Parameter]
    public bool IsMobile { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<string> OnImageCaptured { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<IBrowserFile> OnImageSelected { get; set; }

    private string StatusMessage =>
        _isStartingCamera
            ? "Abrindo camera..."
            : _isCapturingPhoto
                ? "Capturando foto..."
                : "Processando imagem...";

    protected override async Task OnParametersSetAsync()
    {
        if (!AutoStartCamera && (_isCameraActive || _shouldRenderCameraPreview))
        {
            await StopCameraAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (AutoStartCamera && !_shouldRenderCameraPreview && !_isStartingCamera && !_isCameraActive)
        {
            _cameraErrorMessage = null;
            _isStartingCamera = true;
            _shouldRenderCameraPreview = true;
            _pendingCameraStart = true;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (!_pendingCameraStart)
        {
            return;
        }

        _pendingCameraStart = false;
        await StartCameraStreamAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task StartCameraAsync()
    {
        _cameraErrorMessage = null;
        _isStartingCamera = true;
        _shouldRenderCameraPreview = true;
        _pendingCameraStart = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task StartCameraStreamAsync()
    {
        try
        {
            await JsRuntime.InvokeVoidAsync("bookQuotesCamera.startCamera", _videoElementId, _preferredFacingMode);
            _isCameraActive = true;
        }
        catch (JSException ex)
        {
            _cameraErrorMessage = BuildCameraAccessErrorMessage(ex);
            _isCameraActive = false;
            _shouldRenderCameraPreview = false;
        }
        finally
        {
            _isStartingCamera = false;
        }
    }

    private async Task CapturePhotoAsync()
    {
        _cameraErrorMessage = null;
        _isCapturingPhoto = true;

        try
        {
            var imageBase64 = await JsRuntime.InvokeAsync<string>(
                "bookQuotesCamera.captureFrame",
                _videoElementId,
                1600,
                1600,
                0.92);

            await OnImageCaptured.InvokeAsync(imageBase64);
            await StopCameraAsync();
        }
        catch (JSException ex)
        {
            _cameraErrorMessage = BuildCameraCaptureErrorMessage(ex);
        }
        finally
        {
            _isCapturingPhoto = false;
        }
    }

    private async Task ToggleCameraAsync()
    {
        _preferredFacingMode = _preferredFacingMode == "environment" ? "user" : "environment";

        if (_isCameraActive)
        {
            await StartCameraAsync();
        }
    }

    private Task OnFileSelected(InputFileChangeEventArgs eventArgs)
    {
        var file = eventArgs.File;

        if (file is null || file.Size > MaxFileSize)
        {
            return Task.CompletedTask;
        }

        return OnImageSelected.InvokeAsync(file);
    }

    private async Task StopCameraAsync()
    {
        try
        {
            await JsRuntime.InvokeVoidAsync("bookQuotesCamera.stopCamera", _videoElementId);
        }
        catch (JSException)
        {
        }

        _isCameraActive = false;
        _shouldRenderCameraPreview = false;
    }

    private static string BuildCameraAccessErrorMessage(JSException exception)
    {
        var message = exception.Message;

        if (message.Contains("NotAllowedError", StringComparison.OrdinalIgnoreCase))
        {
            return "A camera foi bloqueada pelo navegador ou pelo sistema operacional.";
        }

        if (message.Contains("NotFoundError", StringComparison.OrdinalIgnoreCase))
        {
            return "Nenhuma camera foi encontrada neste dispositivo.";
        }

        if (message.Contains("NotReadableError", StringComparison.OrdinalIgnoreCase))
        {
            return "A camera ja esta em uso por outro aplicativo ou nao pode ser inicializada.";
        }

        if (message.Contains("Elemento de video nao encontrado", StringComparison.OrdinalIgnoreCase))
        {
            return "A visualizacao da camera nao ficou pronta a tempo. Tente novamente.";
        }

        return $"Nao foi possivel abrir a camera. Detalhe: {message}";
    }

    private static string BuildCameraCaptureErrorMessage(JSException exception)
    {
        var message = exception.Message;

        if (message.Contains("nao esta pronta", StringComparison.OrdinalIgnoreCase))
        {
            return "A camera abriu, mas ainda nao estava pronta para capturar. Tente novamente em um instante.";
        }

        return $"Nao foi possivel capturar a foto da camera. Detalhe: {message}";
    }

    private async Task CloseAsync()
    {
        await StopCameraAsync();
        await OnClose.InvokeAsync();
    }

    public async ValueTask DisposeAsync()
    {
        await StopCameraAsync();
    }
}

<style>
    .camera-capture-shell {
        min-height: calc(100dvh - 56px);
        background:
            radial-gradient(circle at top, rgba(255, 255, 255, 0.08), transparent 35%),
            linear-gradient(180deg, #101010 0%, #000000 100%);
        color: white;
    }

    .camera-stage {
        position: relative;
        min-height: calc(100dvh - 56px);
        display: flex;
        align-items: stretch;
        justify-content: center;
    }

    .camera-preview-video,
    .preview-image {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100dvh;
        object-fit: cover;
    }

    .camera-overlay-gradient {
        position: absolute;
        inset: 0;
        background:
            linear-gradient(180deg, rgba(0, 0, 0, 0.7) 0%, transparent 25%, transparent 72%, rgba(0, 0, 0, 0.82) 100%);
        pointer-events: none;
    }

    .camera-top-hint {
        position: absolute;
        top: 24px;
        left: 20px;
        right: 20px;
        z-index: 2;
    }

    .camera-overlay-text {
        color: white;
        text-shadow: 0 1px 10px rgba(0, 0, 0, 0.45);
    }

    .camera-cancel-button {
        color: white !important;
        background: rgba(255, 255, 255, 0.14);
        backdrop-filter: blur(10px);
        border-radius: 999px;
    }

    .camera-cancel-button {
        text-transform: none;
        padding-inline: 14px;
    }

    .camera-focus-frame {
        position: absolute;
        inset: 18% 10% 28% 10%;
        border: 2px solid rgba(255, 255, 255, 0.86);
        border-radius: 28px;
        box-shadow: 0 0 0 9999px rgba(0, 0, 0, 0.2);
        z-index: 1;
        pointer-events: none;
    }

    .camera-controls {
        position: absolute;
        left: 20px;
        right: 20px;
        bottom: calc(24px + env(safe-area-inset-bottom));
        z-index: 2;
    }

    .camera-shutter-button {
        width: 82px;
        height: 82px;
        border-radius: 999px;
        background: white !important;
        color: #111 !important;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.35);
    }

    .camera-secondary-action {
        min-width: 88px;
        justify-content: center;
        padding: 10px 14px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.14);
        color: white !important;
        backdrop-filter: blur(10px);
        text-transform: none;
        cursor: pointer;
    }

    .upload-trigger {
        display: inline-flex;
        align-items: center;
        position: relative;
        overflow: hidden;
    }

    .camera-upload-input {
        position: absolute;
        inset: 0;
        opacity: 0;
        cursor: pointer;
    }

    .camera-placeholder {
        width: 100vw;
        min-height: calc(100dvh - 56px);
        padding: 24px;
        color: rgba(255, 255, 255, 0.82);
    }
</style>
